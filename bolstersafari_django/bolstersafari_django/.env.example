# ════════════════════════════════════════════
# BOLSTER SAFARI — Environment Variables
# Copy this to .env and fill in your values
# ════════════════════════════════════════════

# Django Core
SECRET_KEY=your-super-secret-key-generate-with-python-secrets
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:password@db.yourproject.supabase.co:5432/postgres

# Supabase Storage
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=bolstersafari-media

# AI Providers
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@bolstersafari.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Bolster Safari <noreply@bolstersafari.com>

# Security
SECURE_SSL_REDIRECT=False
ADMIN_URL=secure-admin

# Site
SITE_NAME=Bolster Safari
SITE_URL=http://localhost:8000

# Default Admin Credentials
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@bolstersafari.com
ADMIN_PASSWORD=Admin@12345
