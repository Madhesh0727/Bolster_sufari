{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://bolster-sufari.onrender.com/api/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "https://bolster-sufari.onrender.com/media/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
